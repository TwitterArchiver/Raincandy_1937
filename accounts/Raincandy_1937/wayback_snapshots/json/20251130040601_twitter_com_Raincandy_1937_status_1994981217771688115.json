      },
      {
        "article": {},
        "attachments": {},
        "author_id": "1575765089030139905",
        "conversation_id": "1994850149382983685",
        "created_at": "2025-11-29T19:25:12.000Z",
        "edit_controls": {
          "editable_until": "2025-11-29T20:25:12.000Z",
          "edits_remaining": 5,
